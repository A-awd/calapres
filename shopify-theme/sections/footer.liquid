<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-brand-logo">
          {% if settings.logo_image %}
            <img src="{{ settings.logo_image | img_url: '200x' }}" alt="{{ shop.name }}" style="height:40px;width:auto;filter:brightness(10);">
          {% else %}
            {{ settings.logo_text | default: shop.name }}
          {% endif %}
        </a>
        <p class="footer-about-text">
          {{ settings.footer_about | default: 'كالابريز — عطور فاخرة من قلب الطبيعة. نقدم لك تجربة عطرية استثنائية تجمع بين الأصالة العربية والرقي العالمي.' | strip_html }}
        </p>
        <div class="footer-social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a href="{{ settings.social_twitter }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="Twitter / X">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_snapchat != blank %}
            <a href="{{ settings.social_snapchat }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="Snapchat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.299 4.847l.003.06c-.012.249.078.52.53.54.165.007.344-.012.536-.055.15-.033.308-.053.451-.053.388 0 1.073.168 1.084 1.135.011.902-.75 1.24-1.388 1.33-.138.019-.26.027-.356.036-.258.023-.394.04-.521.2-.134.17-.141.441-.029.919.326 1.379 1.326 3.24 3.484 4.368.395.207.493.526.233.875-.43.575-1.618 1.047-3.427 1.399-.162.03-.267.124-.301.358-.055.392-.073.767-.233 1.118-.164.358-.491.506-.887.513-.417.007-.873-.127-1.434-.343-.556-.213-1.183-.48-1.988-.48-.77 0-1.409.267-1.977.48-.545.207-1.013.342-1.439.342-.478 0-.787-.153-.94-.506-.162-.354-.181-.741-.236-1.132-.034-.23-.139-.325-.301-.354-1.81-.353-2.999-.826-3.429-1.399-.261-.351-.161-.67.235-.877 2.158-1.128 3.158-2.989 3.484-4.368.112-.478.105-.749-.029-.92-.127-.16-.264-.177-.521-.2-.096-.009-.218-.017-.356-.036-.638-.09-1.399-.428-1.388-1.33.011-.967.696-1.135 1.084-1.135.143 0 .301.02.451.053.192.043.371.062.536.055.452-.02.542-.291.53-.54l.003-.06c-.104-1.628-.23-3.654.299-4.847C7.861 1.073 11.228.793 12.206.793z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" class="footer-social-link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.13 8.13 0 004.76 1.52V6.76a4.85 4.85 0 01-.99-.07z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h3 class="footer-col-title">{{ 'footer.quick_links' | t }}</h3>
        <ul class="footer-links">
          <li><a href="/collections" class="footer-link">{{ 'navigation.collections' | t }}</a></li>
          <li><a href="/collections/fragrance-families" class="footer-link">{{ 'navigation.fragrance_families' | t }}</a></li>
          <li><a href="/collections/oud-bakhour" class="footer-link">{{ 'navigation.oud_bakhour' | t }}</a></li>
          <li><a href="/collections/maison" class="footer-link">{{ 'navigation.maison' | t }}</a></li>
          <li><a href="/pages/about" class="footer-link">{{ 'footer.about_us' | t }}</a></li>
        </ul>
      </div>

      <!-- Customer Service -->
      <div class="footer-col">
        <h3 class="footer-col-title">{{ 'footer.customer_service' | t }}</h3>
        <ul class="footer-links">
          <li><a href="/pages/shipping-policy" class="footer-link">{{ 'footer.shipping_policy' | t }}</a></li>
          <li><a href="/policies/refund-policy" class="footer-link">{{ 'footer.return_policy' | t }}</a></li>
          <li><a href="/policies/privacy-policy" class="footer-link">{{ 'footer.privacy_policy' | t }}</a></li>
          <li><a href="/policies/terms-of-service" class="footer-link">{{ 'footer.terms' | t }}</a></li>
          <li><a href="/pages/contact" class="footer-link">{{ 'footer.contact_us' | t }}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h3 class="footer-col-title">{{ 'footer.contact_us' | t }}</h3>
        {% if settings.footer_email != blank %}
          <div class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;margin-top:2px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:{{ settings.footer_email }}" class="footer-link">{{ settings.footer_email }}</a>
          </div>
        {% endif %}
        {% if settings.footer_phone != blank %}
          <div class="footer-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;margin-top:2px;"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.59 9.9 19.79 19.79 0 01.5 1.27 2 2 0 012.47 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.9a16 16 0 006.29 6.29l.79-.79a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            <span>{{ settings.footer_phone }}</span>
          </div>
        {% endif %}
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <div class="container" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem;">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'footer.rights' | t }}.</p>
      <div class="footer-bottom-links">
        <a href="/policies/privacy-policy" class="footer-bottom-link">{{ 'footer.privacy_policy' | t }}</a>
        <a href="/policies/terms-of-service" class="footer-bottom-link">{{ 'footer.terms' | t }}</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
