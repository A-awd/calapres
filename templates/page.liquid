<section class="page-mast wrap center reveal">
  <span class="eyebrow"><span data-ar>كالابريز</span><span data-en>Calapres</span></span>
  <h1 class="display d-1">{{ page.title }}</h1>
  {%- if page.content != blank -%}
    <div class="lede rte">{{ page.content }}</div>
  {%- else -%}
    <p class="lede"><span data-ar>هذه الصفحة قيد التجهيز.</span><span data-en>This page is being prepared.</span></p>
  {%- endif -%}
</section>
