<section class="page-mast wrap center reveal">
  <span class="eyebrow"><span data-ar>كالابريز</span><span data-en>Calapres</span></span>
  <h1 class="display d-1"><span data-ar>بطاقة المتجر</span><span data-en>Store card</span></h1>
  <p class="lede"><span data-ar>استخدم البطاقة عند الدفع في متجر كالابريز.</span><span data-en>Use this card at checkout in the Calapres store.</span></p>
</section>

<section class="section wrap account-narrow">
  <div class="account-card center">
    <span class="eyebrow">{{ gift_card.code | format_code }}</span>
    <h2 class="display d-2">{{ gift_card.balance | money }}</h2>
    {%- if gift_card.expires_on -%}
      <p><span data-ar>تنتهي في</span><span data-en>Expires on</span> {{ gift_card.expires_on | date: "%d %b %Y" }}</p>
    {%- endif -%}
    <div class="page-actions">
      <a class="btn btn-primary" href="/collections/all"><span data-ar>تسوّق الآن</span><span data-en>Shop now</span></a>
    </div>
  </div>
</section>
