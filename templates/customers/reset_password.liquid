<section class="page-mast wrap center reveal">
  <span class="eyebrow"><span data-ar>حساب كالابريز</span><span data-en>Calapres Account</span></span>
  <h1 class="display d-1"><span data-ar>تعيين كلمة مرور جديدة</span><span data-en>Set a new password</span></h1>
</section>

<section class="section wrap account-narrow">
  <div class="account-card">
    {%- form 'reset_customer_password', class: 'contact-form' -%}
      {%- if form.errors -%}<div class="form-error">{{ form.errors | default_errors }}</div>{%- endif -%}
      <label><span><span data-ar>كلمة المرور</span><span data-en>Password</span></span><input type="password" name="customer[password]" autocomplete="new-password" required></label>
      <label><span><span data-ar>تأكيد كلمة المرور</span><span data-en>Confirm password</span></span><input type="password" name="customer[password_confirmation]" autocomplete="new-password" required></label>
      <button class="btn btn-primary" type="submit"><span data-ar>حفظ</span><span data-en>Save</span></button>
    {%- endform -%}
  </div>
</section>
