{%- assign announcement_ar = settings.announcement_text_ar | default: 'شحن مجاني داخل المملكة العربية السعودية على الطلبات فوق ٢٠٠ ر.س' -%}
{%- assign announcement_en = settings.announcement_text_en | default: 'Free shipping across Saudi Arabia on orders over SAR 200' -%}
<div class="announcement-bar" role="region" aria-label="إعلان" data-announcement-bar>
  <p>
    <span data-ar>{{ announcement_ar }}</span>
    <span data-en>{{ announcement_en }}</span>
  </p>
  <button class="announcement-close" type="button" aria-label="إغلاق الإعلان" data-announcement-close>&times;</button>
</div>
