<div class="filters-bar">
  <div class="filter-chips" data-filter-chips>
    <button class="chip active" data-filter="*"><span data-ar>الكل</span><span data-en>All</span></button>
    <button class="chip" data-filter="ورديّ"><span data-ar>ورديّ</span><span data-en>Rosy</span></button>
    <button class="chip" data-filter="خشبيّ"><span data-ar>خشبيّ</span><span data-en>Woody</span></button>
    <button class="chip" data-filter="عنبريّ"><span data-ar>عنبريّ</span><span data-en>Ambery</span></button>
    <button class="chip" data-filter="مسكيّ"><span data-ar>مسكيّ</span><span data-en>Musky</span></button>
    <button class="chip" data-filter="حمضيّ"><span data-ar>حمضيّ</span><span data-en>Citrus</span></button>
    <button class="chip" data-filter="شرقيّ"><span data-ar>شرقيّ</span><span data-en>Oriental</span></button>
  </div>
  <div class="sort-wrap">
    <select class="sort-sel" data-sort>
      <option value="manual"><span data-ar>مقترح</span><span data-en>Featured</span></option>
      <option value="price-asc"><span data-ar>السعر: من الأقل</span><span data-en>Price: Low to High</span></option>
      <option value="price-desc"><span data-ar>السعر: من الأعلى</span><span data-en>Price: High to Low</span></option>
      <option value="title-asc"><span data-ar>الاسم: أ—ي</span><span data-en>Name: A–Z</span></option>
      <option value="created-desc"><span data-ar>الأحدث أولًا</span><span data-en>Newest first</span></option>
    </select>
  </div>
</div>
