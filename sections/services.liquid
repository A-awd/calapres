<section class="section wrap services" id="services">
  <div class="sec-head">
    <div class="ttl reveal">
      <span class="eyebrow"><span data-ar>{{ section.settings.eyebrow_ar }}</span><span data-en>{{ section.settings.eyebrow_en }}</span></span>
      <h2 class="display d-2"><span data-ar>{{ section.settings.heading_ar }}</span><span data-en>{{ section.settings.heading_en }}</span></h2>
    </div>
    <p class="lede reveal"><span data-ar>{{ section.settings.lede_ar }}</span><span data-en>{{ section.settings.lede_en }}</span></p>
  </div>
  <div class="grid">
    <div class="svc reveal">
      <div class="ico"><svg viewBox="0 0 32 32"><path d="M13 4h6M14 4v5l-3 6v11a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V15l-3-6V4"/><path d="M11 19h10"/></svg></div>
      <h3><span data-ar>عيّنات الاكتشاف</span><span data-en>Discovery samples</span></h3>
      <p><span data-ar>عيّنات ٢ مل من النيش والعود، لتختار رائحتك قبل القارورة.</span><span data-en>2ml niche and oud samples, to find your scent before the bottle.</span></p>
    </div>
    <div class="svc reveal d1">
      <div class="ico"><svg viewBox="0 0 32 32"><path d="M5 7h22v15H14l-6 5v-5H5z"/><path d="M11 13h10M11 17h6"/></svg></div>
      <h3><span data-ar>استشارة عطرية</span><span data-en>Scent consultation</span></h3>
      <p><span data-ar>خبراء الدار يرشّحون لك العطر الأنسب لذوقك ومناسبتك.</span><span data-en>Our experts recommend the scent that suits your taste and occasion.</span></p>
    </div>
    <div class="svc reveal d2">
      <div class="ico"><svg viewBox="0 0 32 32"><path d="M3 8h15v11H3zM18 12h6l4 4v3h-10z"/><circle cx="9" cy="23" r="2.4"/><circle cx="23" cy="23" r="2.4"/></svg></div>
      <h3><span data-ar>توصيل الرياض</span><span data-en>Riyadh delivery</span></h3>
      <p><span data-ar>توصيل سريع داخل الرياض، وشحن مدروس لبقية المملكة.</span><span data-en>Swift delivery across Riyadh, careful shipping to the Kingdom.</span></p>
    </div>
    <div class="svc reveal d3">
      <div class="ico"><svg viewBox="0 0 32 32"><path d="M16 4l9 3v7c0 6-4 10-9 13-5-3-9-7-9-13V7z"/><path d="M11.5 15.5l3 3 6-6.5"/></svg></div>
      <h3><span data-ar>ضمان الأصالة</span><span data-en>Authenticity guaranteed</span></h3>
      <p><span data-ar>كل عطر وقطعة عود أصلية ١٠٠٪ من مصادرها المعتمدة.</span><span data-en>Every perfume and oud is 100% authentic from approved sources.</span></p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_ar",
      "label": "Eyebrow Arabic",
      "default": "خدمة الدار"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow English",
      "default": "Maison service"
    },
    {
      "type": "text",
      "id": "heading_ar",
      "label": "Heading Arabic",
      "default": "كل ما تحتاجه الرائحة"
    },
    {
      "type": "text",
      "id": "heading_en",
      "label": "Heading English",
      "default": "Everything the scent needs"
    },
    {
      "type": "textarea",
      "id": "lede_ar",
      "label": "Intro Arabic",
      "default": "من عيّنات الاكتشاف إلى التوصيل في الرياض، نهتم بالتفاصيل التي تصنع تجربة العطر."
    },
    {
      "type": "textarea",
      "id": "lede_en",
      "label": "Intro English",
      "default": "From discovery samples to delivery across Riyadh, we tend to the details that make the scent experience."
    }
  ],
  "presets": [
    {
      "name": "Services"
    }
  ]
}
{% endschema %}
