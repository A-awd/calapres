<section class="section wrap category-ocean" id="category-ocean">
  <div class="sec-head">
    <div class="ttl reveal">
      <span class="eyebrow"><span data-ar>{{ section.settings.eyebrow_ar }}</span><span data-en>{{ section.settings.eyebrow_en }}</span></span>
      <h2 class="display d-2"><span data-ar>{{ section.settings.heading_ar }}</span><span data-en>{{ section.settings.heading_en }}</span></h2>
    </div>
    <p class="lede reveal"><span data-ar>{{ section.settings.lede_ar }}</span><span data-en>{{ section.settings.lede_en }}</span></p>
  </div>

  <div class="ocean-feature-grid">
    <a class="ocean-feature reveal" href="/collections/niche">
      <span class="ocean-kicker"><span data-ar>النوع</span><span data-en>Type</span></span>
      <strong><span data-ar>عطور النيش</span><span data-en>Niche perfumes</span></strong>
      <span><span data-ar>تركيبات نادرة، دور مستقلة، وروائح لا تشبه العابر.</span><span data-en>Rare compositions, independent houses and scents beyond the obvious.</span></span>
    </a>
    <a class="ocean-feature reveal d1" href="/collections/luxury-brands">
      <span class="ocean-kicker"><span data-ar>البراند</span><span data-en>Brand</span></span>
      <strong><span data-ar>البراندات الفاخرة</span><span data-en>Luxury brands</span></strong>
      <span><span data-ar>دور عالمية، أيقونات معروفة، واختيارات مجرّبة بعناية.</span><span data-en>Global houses, recognizable icons and carefully chosen signatures.</span></span>
    </a>
    <a class="ocean-feature reveal d2 ocean-feature--gold" href="/search?q=%D9%85%D8%A8%D8%AE%D8%B1%20%D9%83%D8%A7%D9%84%D8%A7%D8%A8%D8%B1%D9%8A%D8%B2">
      <span class="ocean-kicker"><span data-ar>خط خاص</span><span data-en>Private line</span></span>
      <strong><span data-ar>مبخر كالابريز</span><span data-en>Calapres Mabkhar</span></strong>
      <span><span data-ar>مباخرنا الخاصة للعود والبخور، مصممة لتكون جزءًا من طقس الرائحة.</span><span data-en>Our own burners for oud and bukhoor, made for the ritual of scent.</span></span>
    </a>
  </div>

  <div class="ocean-panels">
    <div class="ocean-panel reveal">
      <h3><span data-ar>تسوّق حسب المنتج</span><span data-en>Shop by product</span></h3>
      <div class="ocean-links">
        <a href="/collections/niche"><span data-ar>عطور نيش</span><span data-en>Niche perfumes</span></a>
        <a href="/collections/luxury-brands"><span data-ar>عطور ديزاينر</span><span data-en>Designer perfumes</span></a>
        <a href="/collections/oriental"><span data-ar>عطور شرقية</span><span data-en>Oriental perfumes</span></a>
        <a href="/collections/oud-bakhour"><span data-ar>عود وبخور</span><span data-en>Oud and bukhoor</span></a>
        <a href="/search?q=hair%20mist"><span data-ar>عطور الشعر</span><span data-en>Hair mists</span></a>
        <a href="/search?q=body%20mist"><span data-ar>عطور الجسم</span><span data-en>Body mists</span></a>
        <a href="/search?q=body%20powder"><span data-ar>بودرة معطرة</span><span data-en>Scented body powder</span></a>
        <a href="/search?q=perfume%20oil"><span data-ar>زيوت عطرية</span><span data-en>Perfume oils</span></a>
        <a href="/search?q=gift%20set"><span data-ar>مجموعات عطرية</span><span data-en>Fragrance sets</span></a>
      </div>
    </div>

    <div class="ocean-panel reveal d1">
      <h3><span data-ar>تسوّق حسب العائلة العطرية</span><span data-en>Shop by scent family</span></h3>
      <div class="ocean-links">
        <a href="/search?q=citrus%20perfume"><span data-ar>حمضية</span><span data-en>Citrus</span></a>
        <a href="/search?q=woody%20perfume"><span data-ar>خشبية</span><span data-en>Woody</span></a>
        <a href="/collections/oud-bakhour"><span data-ar>عود</span><span data-en>Oud</span></a>
        <a href="/search?q=leather%20perfume"><span data-ar>جلدية</span><span data-en>Leather</span></a>
        <a href="/collections/oriental"><span data-ar>عنبرية</span><span data-en>Amber</span></a>
        <a href="/search?q=floral%20perfume"><span data-ar>زهرية</span><span data-en>Floral</span></a>
        <a href="/search?q=musk%20perfume"><span data-ar>مسكية</span><span data-en>Musk</span></a>
        <a href="/search?q=powdery%20perfume"><span data-ar>بودرية</span><span data-en>Powdery</span></a>
        <a href="/search?q=vanilla%20perfume"><span data-ar>فانيلا</span><span data-en>Vanilla</span></a>
        <a href="/search?q=aromatic%20perfume"><span data-ar>أروماتيك</span><span data-en>Aromatic</span></a>
        <a href="/search?q=fruity%20perfume"><span data-ar>فاكهية</span><span data-en>Fruity</span></a>
        <a href="/search?q=tobacco%20perfume"><span data-ar>تبغ</span><span data-en>Tobacco</span></a>
      </div>
    </div>

    <div class="ocean-panel reveal d2">
      <h3><span data-ar>تسوّق حسب البراند</span><span data-en>Shop by brand</span></h3>
      <div class="ocean-links">
        <a href="/search?q=Tom%20Ford">Tom Ford</a>
        <a href="/search?q=Dior">Dior</a>
        <a href="/search?q=Nishane">Nishane</a>
        <a href="/search?q=Xerjoff">Xerjoff</a>
        <a href="/search?q=Maison%20Crivelli">Maison Crivelli</a>
        <a href="/search?q=Jean%20Paul%20Gaultier">Jean Paul Gaultier</a>
        <a href="/search?q=Givenchy">Givenchy</a>
        <a href="/search?q=Kenzo">Kenzo</a>
        <a href="/search?q=Van%20Cleef">Van Cleef &amp; Arpels</a>
        <a href="/search?q=Clinique">Clinique</a>
        <a href="/search?q=Caron">Caron</a>
        <a href="/search?q=Ralph%20Lauren">Ralph Lauren</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Ocean",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_ar",
      "label": "Eyebrow Arabic",
      "default": "دليل كالابريز"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow English",
      "default": "Calapres guide"
    },
    {
      "type": "text",
      "id": "heading_ar",
      "label": "Heading Arabic",
      "default": "بحر من العطور حسب النوع والرائحة والبراند"
    },
    {
      "type": "text",
      "id": "heading_en",
      "label": "Heading English",
      "default": "A scent universe by type, family and brand"
    },
    {
      "type": "textarea",
      "id": "lede_ar",
      "label": "Intro Arabic",
      "default": "اختر من عطور النيش والديزاينر، عطور الشعر والجسم، العائلات العطرية، والبراندات التي تحبها."
    },
    {
      "type": "textarea",
      "id": "lede_en",
      "label": "Intro English",
      "default": "Browse niche and designer perfume, hair and body mists, scent families and the brands you love."
    }
  ],
  "presets": [
    {
      "name": "Category Ocean"
    }
  ]
}
{% endschema %}
