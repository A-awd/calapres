<footer class="site-footer" role="contentinfo">
  <div class="wrap footer-grid">
    <div class="footer-col">
      <div class="footer-brand"><span data-ar>كالابريز</span><span data-en>Calapres</span></div>
      <p style="color:rgba(239,233,221,.72);max-width:34ch;font-size:14px">
        <span data-ar>{{ section.settings.tagline_ar | default: 'بيت عطور النيش والعود الفاخر والمباخر. رائحةٌ تُروى ولا تُنسى.' }}</span>
        <span data-en>{{ section.settings.tagline_en | default: 'A house of niche perfume, fine oud and bukhoor. A scent that is told, never forgotten.' }}</span>
      </p>
    </div>
    <div class="footer-col">
      <h4><span data-ar>تسوّق</span><span data-en>Shop</span></h4>
      <ul>
        <li><a href="/collections/niche"><span data-ar>عطور النيش</span><span data-en>Niche Perfumes</span></a></li>
        <li><a href="/collections/oriental"><span data-ar>العطور الشرقية</span><span data-en>Oriental Perfumes</span></a></li>
        <li><a href="/collections/oud-bakhour"><span data-ar>العود والمباخر</span><span data-en>Oud &amp; Bukhoor</span></a></li>
        <li><a href="/collections/luxury-brands"><span data-ar>البراندات الفاخرة</span><span data-en>Luxury Brands</span></a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4><span data-ar>الميزون</span><span data-en>Maison</span></h4>
      <ul>
        <li><a href="/pages/about"><span data-ar>قصّتنا</span><span data-en>Our story</span></a></li>
        <li><a href="/pages/discovery-samples"><span data-ar>عيّنات الاكتشاف</span><span data-en>Discovery samples</span></a></li>
        <li><a href="/blogs/journal"><span data-ar>المجلّة</span><span data-en>Journal</span></a></li>
        <li><a href="/pages/faq"><span data-ar>الأسئلة الشائعة</span><span data-en>FAQ</span></a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4><span data-ar>تواصل</span><span data-en>Contact</span></h4>
      <ul>
        {% if settings.social_instagram != blank %}
          <li><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener"><span data-ar>إنستغرام</span><span data-en>Instagram</span></a></li>
        {% endif %}
        {% if settings.footer_whatsapp != blank %}
          <li><a href="https://wa.me/{{ settings.footer_whatsapp }}"><span data-ar>واتساب</span><span data-en>WhatsApp</span></a></li>
        {% endif %}
        {% if settings.footer_email != blank %}
          <li><a href="mailto:{{ settings.footer_email }}">{{ settings.footer_email }}</a></li>
        {% endif %}
        <li><a href="/pages/contact"><span data-ar>السعودية والخليج</span><span data-en>Saudi Arabia and the Gulf</span></a></li>
      </ul>
    </div>
  </div>
  <div class="wrap footer-bottom">
    <span><span data-ar>© ٢٠٢٦ كالابريز</span><span data-en>© 2026 Calapres</span></span>
    <span><span data-ar>مختار بعناية للسعودية والخليج</span><span data-en>Curated with care for Saudi Arabia and the Gulf</span></span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline_ar", "label": "Tagline (Arabic)", "default": "بيت عطور النيش والعود الفاخر والمباخر. رائحةٌ تُروى ولا تُنسى." },
    { "type": "text", "id": "tagline_en", "label": "Tagline (English)", "default": "A house of niche perfume, fine oud and bukhoor. A scent that is told, never forgotten." }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
