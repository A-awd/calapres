<section class="section wrap" id="occasions">
  <div class="sec-head">
    <div class="ttl reveal">
      <span class="eyebrow"><span data-ar>{{ section.settings.eyebrow_ar }}</span><span data-en>{{ section.settings.eyebrow_en }}</span></span>
      <h2 class="display d-2"><span data-ar>{{ section.settings.heading_ar }}</span><span data-en>{{ section.settings.heading_en }}</span></h2>
    </div>
  </div>
  <div class="occasions-grid">
    <a class="occ feature reveal" href="{{ section.settings.oud_url | default: '/collections/oud-bakhour' }}">
      <img src="{{ 'c-oud.jpg' | asset_url }}" alt="" width="1200" height="1500" loading="lazy" />
      <span class="lbl"><span class="k"><span data-ar>التوقيع</span><span data-en>Signature</span></span><span class="nm"><span data-ar>العود والأخشاب</span><span data-en>Oud &amp; Woods</span></span></span>
    </a>
    <a class="occ reveal d1" href="{{ section.settings.floral_url | default: '/collections/floral' }}">
      <img src="{{ 'pr-rose.jpg' | asset_url }}" alt="" width="1200" height="1500" loading="lazy" />
      <span class="lbl"><span class="k"><span data-ar>ناعمة</span><span data-en>Soft</span></span><span class="nm"><span data-ar>الورديات</span><span data-en>Florals</span></span></span>
    </a>
    <a class="occ reveal d2" href="{{ section.settings.amber_url | default: '/collections/amber' }}">
      <img src="{{ 'pr-amber.jpg' | asset_url }}" alt="" width="1200" height="1500" loading="lazy" />
      <span class="lbl"><span class="k"><span data-ar>دافئة</span><span data-en>Warm</span></span><span class="nm"><span data-ar>الشرقيات والعنبر</span><span data-en>Orientals &amp; Amber</span></span></span>
    </a>
    <a class="occ reveal d1" href="{{ section.settings.musk_url | default: '/collections/musk' }}">
      <img src="{{ 'pr-musk.jpg' | asset_url }}" alt="" width="1200" height="1500" loading="lazy" />
      <span class="lbl"><span class="k"><span data-ar>نقية</span><span data-en>Clean</span></span><span class="nm"><span data-ar>المسك</span><span data-en>Musk</span></span></span>
    </a>
    <a class="occ reveal d2" href="{{ section.settings.citrus_url | default: '/collections/citrus' }}">
      <img src="{{ 'c-oriental.jpg' | asset_url }}" alt="" width="1200" height="1500" loading="lazy" />
      <span class="lbl"><span class="k"><span data-ar>منعشة</span><span data-en>Fresh</span></span><span class="nm"><span data-ar>الحمضيات</span><span data-en>Citrus</span></span></span>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Scent Families",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_ar",
      "label": "Eyebrow Arabic",
      "default": "اكتشف حسب الرائحة"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow English",
      "default": "Find by scent"
    },
    {
      "type": "text",
      "id": "heading_ar",
      "label": "Heading Arabic",
      "default": "عائلات عطرية تختار منها"
    },
    {
      "type": "text",
      "id": "heading_en",
      "label": "Heading English",
      "default": "Olfactive families to choose from"
    },
    {
      "type": "url",
      "id": "oud_url",
      "label": "Oud collection URL"
    },
    {
      "type": "url",
      "id": "floral_url",
      "label": "Floral collection URL"
    },
    {
      "type": "url",
      "id": "amber_url",
      "label": "Amber collection URL"
    },
    {
      "type": "url",
      "id": "musk_url",
      "label": "Musk collection URL"
    },
    {
      "type": "url",
      "id": "citrus_url",
      "label": "Citrus collection URL"
    }
  ],
  "presets": [
    {
      "name": "Scent Families"
    }
  ]
}
{% endschema %}
