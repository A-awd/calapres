{%- assign has_hero_image = false -%}
{%- if section.settings.hero_image -%}
  {%- assign has_hero_image = true -%}
{%- endif -%}
<section class="hero{% unless has_hero_image %} hero--fallback{% endunless %}" data-hero-sentinel data-screen-label="hero">
  <div class="hero__img">
    {%- if has_hero_image -%}
      <img src="{{ section.settings.hero_image | img_url: '1920x' }}" alt="" width="1920" height="1080" fetchpriority="high" />
    {%- else -%}
      <div class="hero__fallback" aria-hidden="true"></div>
    {%- endif -%}
  </div>
  <div class="hero__inner wrap">
    <span class="eyebrow reveal">
      <span data-ar>{{ section.settings.eyebrow_ar | default: 'بيت عطور النيش والمباخر' }}</span>
      <span data-en>{{ section.settings.eyebrow_en | default: 'House of Niche Perfume and Bukhoor' }}</span>
    </span>
    <div class="hero-title reveal d1">
      <h1 class="display d-hero hero-title__ar">{{ section.settings.heading_ar | default: 'رائحة تُروى ولا تُنسى' }}</h1>
      <p class="hero-title__en">{{ section.settings.heading_en | default: 'A scent that is told, never forgotten' }}</p>
    </div>
    <p class="sub reveal d2">
      <span data-ar>{{ section.settings.sub_ar | default: 'عطور نيش عالمية، عودٌ فاخر، ومباخر — مُنتقاةٌ بعنايةٍ لعشّاق الرائحة في السعودية والخليج. فنّ العطر، مُتقَنًا.' }}</span>
      <span data-en>{{ section.settings.sub_en | default: 'Niche perfumes, rare oud and bukhoor — curated with care for the scent-led across Saudi Arabia and the Gulf. The art of perfume, perfected.' }}</span>
    </p>
    <div class="cta reveal d3">
      <a class="btn btn-primary" href="{{ section.settings.cta1_url | default: '/collections' }}">
        <span data-ar>{{ section.settings.cta1_ar | default: 'اكتشف المجموعات' }}</span>
        <span data-en>{{ section.settings.cta1_en | default: 'Discover collections' }}</span>
      </a>
      <a class="btn btn-secondary{% if has_hero_image %} on-dark{% endif %}" href="{{ section.settings.cta2_url | default: '#signature' }}">
        <span data-ar>{{ section.settings.cta2_ar | default: 'العود والمباخر' }}</span>
        <span data-en>{{ section.settings.cta2_en | default: 'Oud & Bukhoor' }}</span>
      </a>
    </div>
    <div class="hero__trustbar reveal d4" aria-label="مزايا كالابريز" data-home-polish-sync="20260605">
      <span><span data-ar>أصالة مضمونة</span><span data-en>Authenticity assured</span></span>
      <span><span data-ar>عطور نيش عالمية</span><span data-en>Global niche perfume</span></span>
      <span><span data-ar>عود ومباخر فاخرة</span><span data-en>Luxury oud and burners</span></span>
    </div>
  </div>
  <div class="scroll-hint"><span class="ln"></span><span data-ar>اسحب للأسفل</span><span data-en>Scroll</span></div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Background Image" },
    { "type": "text", "id": "eyebrow_ar", "label": "Eyebrow (Arabic)", "default": "بيت عطور النيش والمباخر" },
    { "type": "text", "id": "eyebrow_en", "label": "Eyebrow (English)", "default": "House of Niche Perfume and Bukhoor" },
    { "type": "text", "id": "heading_ar", "label": "Heading (Arabic)", "default": "رائحة تُروى ولا تُنسى" },
    { "type": "text", "id": "heading_en", "label": "Heading (English)", "default": "A scent that is told, never forgotten" },
    { "type": "textarea", "id": "sub_ar", "label": "Subtext (Arabic)" },
    { "type": "textarea", "id": "sub_en", "label": "Subtext (English)" },
    { "type": "text", "id": "cta1_ar", "label": "CTA 1 (Arabic)", "default": "اكتشف المجموعات" },
    { "type": "text", "id": "cta1_en", "label": "CTA 1 (English)", "default": "Discover collections" },
    { "type": "url",  "id": "cta1_url", "label": "CTA 1 URL" },
    { "type": "text", "id": "cta2_ar", "label": "CTA 2 (Arabic)", "default": "العود والمباخر" },
    { "type": "text", "id": "cta2_en", "label": "CTA 2 (English)", "default": "Oud & Bukhoor" },
    { "type": "url",  "id": "cta2_url", "label": "CTA 2 URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
