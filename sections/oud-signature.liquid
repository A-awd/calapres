<section class="signature" id="signature" data-screen-label="oud-story">
  {%- if section.settings.image -%}
    <img src="{{ section.settings.image | img_url: '1800x1200', crop: 'center' }}" alt="" width="1800" height="1200" loading="lazy" />
  {%- else -%}
    <img src="{{ 'p-signature.jpg' | asset_url }}" alt="" width="1800" height="1200" loading="lazy" />
  {%- endif -%}
  <div class="wrap">
    <div class="inner reveal">
      <span class="eyebrow"><span data-ar>{{ section.settings.eyebrow_ar }}</span><span data-en>{{ section.settings.eyebrow_en }}</span></span>
      <h2 class="display d-1"><span data-ar>{{ section.settings.heading_ar }}</span><span data-en>{{ section.settings.heading_en }}</span></h2>
      <p><span data-ar>{{ section.settings.body_ar }}</span><span data-en>{{ section.settings.body_en }}</span></p>
      <div style="margin-top:var(--s4)">
        <a class="btn btn-secondary on-dark" href="{{ section.settings.cta_url | default: '/collections/oud-bakhour' }}">
          <span data-ar>{{ section.settings.cta_ar }}</span><span data-en>{{ section.settings.cta_en }}</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Oud Signature",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow_ar",
      "label": "Eyebrow Arabic",
      "default": "عود كالابريز"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow English",
      "default": "Calapres Oud"
    },
    {
      "type": "text",
      "id": "heading_ar",
      "label": "Heading Arabic",
      "default": "رائحة تبدأ القصة"
    },
    {
      "type": "text",
      "id": "heading_en",
      "label": "Heading English",
      "default": "A scent that begins the story"
    },
    {
      "type": "textarea",
      "id": "body_ar",
      "label": "Body Arabic",
      "default": "عود معتّق، عنبر نادر، ومباخر تختار بعناية. كل قطرة وكل قطعة تحمل أصالة المصدر لتجعل من لحظة العطر تجربة لا تنسى."
    },
    {
      "type": "textarea",
      "id": "body_en",
      "label": "Body English",
      "default": "Aged oud, rare amber, and bukhoor chosen with care. Every drop and every piece carries the authenticity of its source."
    },
    {
      "type": "text",
      "id": "cta_ar",
      "label": "CTA Arabic",
      "default": "اكتشف العود"
    },
    {
      "type": "text",
      "id": "cta_en",
      "label": "CTA English",
      "default": "Explore the oud"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Oud Signature"
    }
  ]
}
{% endschema %}
